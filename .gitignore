# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

#Zip files
*.zip

# local Codex/reference files (DLL/PDFs/decompilado em C# ficam só locais,
# nunca vão pro git - binarios grandes/sensiveis). Excecao: o porte Python
# fiel em decompiled_python/ E versionado de proposito (texto leve, util
# pra qualquer maquina/sessao - ver CLAUDE.md).
_referencias/*
!_referencias/simulador-oficial/
_referencias/simulador-oficial/*
!_referencias/simulador-oficial/decompiled_python/
.codex/

# dependencies
/node_modules
__pycache__/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# logs de sessao do engine_server (diagnostico ao vivo do bot, efemero --
# NAO e o banco de combat logs, que fica em scriptis_da_ia/logs/ e E
# versionado de proposito, ver CLAUDE.md)
BOT/engine_server/logs/
scriptis_da_ia/metrics/live_runs/

# env files (can opt-in for committing if needed)
.env*

# saidas efemeras do auditor de decisao (audit_antipatterns.py) e debug de
# OCR/bbox — experimentos descartaveis, nao sao o banco de logs versionado
scriptis_da_ia/decision_audit_*.json
scriptis_da_ia/_debug_prompt_bbox/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
